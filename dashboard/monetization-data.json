      "categories": {
        "display_advertising": {
          "score": 15,
          "opportunities": 2,
          "rationale": "Very poor fit. Admin interface is not a place for ads. Public gallery view (client-facing) would degrade professional brand and UX. Possible only on public landing page (galleries listing) or marketing blog. CPM rates ($5-10) insufficient to justify implementation complexity. Low traffic volume for programmatic advertising thresholds."
        },
        "affiliate_marketing": {
          "score": 42,
          "opportunities": 4,
          "rationale": "Moderate fit. Relevant affiliate programs exist (camera gear, print services, software). Can be integrated into: (1) marketing blog content (tutorials, gear guides), (2) optional equipment recommendations in photographer dashboard, (3) affiliate links embedded in client-facing materials. Revenue stream secondary but viable ($100-300/month at scale). Low implementation cost if done organically (blog + dashboard recs)."
        },
        "premium_features": {
          "score": 85,
          "opportunities": 6,
          "rationale": "Excellent fit and primary monetization lever. Clear feature differentiation for freemium tiers: storage limits, gallery/photo limits, client user limits, analytics depth, API access, custom domains. Competitive pricing: $30-60/month for paid tiers. Analogify's unique value (deterministic processing, approval workflow) supports higher-end positioning. Requires: subscription infrastructure, feature gates in code, billing UI. Medium engineering lift (2-3 weeks initial, ongoing)."
        },
        "print_fulfillment": {
          "score": 78,
          "opportunities": 5,
          "rationale": "Excellent fit and proven revenue model. Integration with WHCC, Bay Photo, Printful for on-demand fulfillment. Photographer-set pricing with platform commission (12-20% standard). Can co-exist with subscription model: platform revenue = subscription + commission on orders. Client gallery would have 'Order Prints' button linking to print vendor. Estimated revenue: $1-2K/month at 100 photographers with average order value $100. Requires: print vendor API integration, photographer markup settings, order tracking. Medium lift (2-4 weeks)."
        },
        "digital_products": {
          "score": 58,
          "opportunities": 4,
          "rationale": "Good fit for medium-term expansion. Three distinct product lines: (1) Paid photo downloads (photographer controls price/availability), (2) Presets (ChromaHaus styles as Lightroom/Capture One presets), (3) Templates (gallery templates, client communication templates). Revenue model: Platform takes 30% commission on downloads/preset sales, or bundled into premium tier. Requires: digital delivery infrastructure, photographer pricing controls, delivery tracking. Low to medium lift (3-5 weeks for full implementation)."
        },
        "client_services": {
          "score": 64,
          "opportunities": 4,
          "rationale": "Good fit for tiering strategy. Can monetize: (1) Platform fees on transactions (print commission already captured, but could add 2-3% payment processing fee visibility), (2) Storage overage fees (e.g., $1/10GB after free tier), (3) Client account tiers (premium analytics dashboard for photographers), (4) Advanced features (API access, white-label options). These stack with subscription tier but remain optional. Revenue: $300-500/month at scale. Low lift (1-2 weeks for storage metering + analytics)."
        },
        "sponsorships": {
          "score": 28,
          "opportunities": 2,
          "rationale": "Low fit for current stage. Relevant partnerships exist (camera brands, photo service companies), but Analogify is not yet high-traffic enough to command sponsorship revenue. Could revisit at 10K+ active photographers. Possible partnerships: (1) Fujifilm/Canon sponsoring ChromaHaus styles, (2) Adobe/Capture One integration partnerships. Revenue: $500-1K/month at scale. Defer to Phase 3-4."
        }
      }
