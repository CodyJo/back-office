{
  "uid": "llm-inference",
  "title": "LLM Inference — Ollama",
  "tags": ["monitoring", "ollama", "llm"],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "editable": true,
  "refresh": "1m",
  "graphTooltip": 0,
  "time": {
    "from": "now-6h",
    "to": "now"
  },
  "annotations": {
    "list": [
      {
        "builtIn": 1,
        "datasource": {
          "type": "datasource",
          "uid": "-- Grafana --"
        },
        "enable": true,
        "hide": true,
        "iconColor": "rgba(0, 211, 255, 1)",
        "name": "Annotations & Alerts",
        "type": "dashboard"
      }
    ]
  },
  "templating": {
    "list": [
      {
        "name": "model",
        "label": "Model",
        "type": "query",
        "datasource": { "uid": "timescaledb", "type": "postgres" },
        "refresh": 1,
        "sort": 1,
        "multi": false,
        "includeAll": false,
        "definition": "SELECT DISTINCT labels->>'model' AS model FROM metrics_5m WHERE metric = 'ollama_model_vram_ratio' AND $__timeFilter(bucket) ORDER BY 1",
        "query": "SELECT DISTINCT labels->>'model' AS model FROM metrics_5m WHERE metric = 'ollama_model_vram_ratio' AND $__timeFilter(bucket) ORDER BY 1",
        "current": {
          "selected": false,
          "text": "",
          "value": ""
        }
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "type": "gauge",
      "title": "VRAM Ratio — $model",
      "repeat": "model",
      "repeatDirection": "h",
      "maxPerRow": 4,
      "gridPos": { "h": 7, "w": 6, "x": 0, "y": 0 },
      "datasource": { "uid": "timescaledb", "type": "postgres" },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "min": 0,
          "max": 1.2,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "green", "value": 1.0 }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "orientation": "auto",
        "reduceOptions": { "values": false, "calcs": ["lastNotNull"], "fields": "" },
        "showThresholdLabels": true,
        "showThresholdMarkers": true
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "uid": "timescaledb", "type": "postgres" },
          "editorMode": "code",
          "format": "time_series",
          "rawQuery": true,
          "rawSql": "SELECT bucket AS time, avg_val AS value FROM metrics_5m WHERE metric = 'ollama_model_vram_ratio' AND labels->>'model' = '$model' AND $__timeFilter(bucket) ORDER BY bucket"
        }
      ]
    },
    {
      "id": 2,
      "type": "table",
      "title": "Models Status",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 7 },
      "datasource": { "uid": "timescaledb", "type": "postgres" },
      "fieldConfig": {
        "defaults": {},
        "overrides": []
      },
      "options": {
        "cellHeight": "sm",
        "footer": { "show": false }
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "uid": "timescaledb", "type": "postgres" },
          "editorMode": "code",
          "format": "table",
          "rawQuery": true,
          "rawSql": "WITH latest AS (SELECT DISTINCT ON (labels->>'model', metric) labels->>'model' AS model, metric, avg_val FROM metrics_5m WHERE metric IN ('ollama_model_loaded', 'ollama_model_vram_ratio', 'ollama_model_size_bytes') AND $__timeFilter(bucket) ORDER BY labels->>'model', metric, bucket DESC) SELECT model, max(CASE WHEN metric = 'ollama_model_loaded' THEN avg_val END) AS loaded, max(CASE WHEN metric = 'ollama_model_vram_ratio' THEN avg_val END) AS vram_ratio, max(CASE WHEN metric = 'ollama_model_size_bytes' THEN avg_val END) AS size_bytes FROM latest GROUP BY model ORDER BY model"
        }
      ]
    },
    {
      "id": 3,
      "type": "timeseries",
      "title": "VRAM Ratio History",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 7 },
      "datasource": { "uid": "timescaledb", "type": "postgres" },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": { "mode": "palette-classic" },
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 8,
            "lineWidth": 2,
            "showPoints": "never",
            "spanNulls": true
          }
        },
        "overrides": []
      },
      "options": {
        "legend": { "displayMode": "table", "placement": "bottom", "showLegend": true },
        "tooltip": { "mode": "multi", "sort": "desc" }
