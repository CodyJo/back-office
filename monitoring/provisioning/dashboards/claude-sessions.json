{
  "uid": "claude-sessions",
  "title": "Claude Code Sessions",
  "tags": ["monitoring", "claude", "sessions"],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "editable": true,
  "refresh": "1m",
  "graphTooltip": 0,
  "time": {
    "from": "now-6h",
    "to": "now"
  },
  "annotations": {
    "list": [
      {
        "builtIn": 1,
        "datasource": {
          "type": "datasource",
          "uid": "-- Grafana --"
        },
        "enable": true,
        "hide": true,
        "iconColor": "rgba(0, 211, 255, 1)",
        "name": "Annotations & Alerts",
        "type": "dashboard"
      }
    ]
  },
  "templating": {
    "list": []
  },
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "Active Sessions",
      "gridPos": { "h": 7, "w": 6, "x": 0, "y": 0 },
      "datasource": { "uid": "timescaledb", "type": "postgres" },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": { "mode": "value" }
        },
        "overrides": []
      },
      "options": {
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "center",
        "orientation": "horizontal",
        "reduceOptions": { "values": false, "calcs": ["lastNotNull"], "fields": "" },
        "textMode": "value_and_name"
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "uid": "timescaledb", "type": "postgres" },
          "editorMode": "code",
          "format": "time_series",
          "rawQuery": true,
          "rawSql": "SELECT bucket AS time, avg_val AS value FROM metrics_5m WHERE metric = 'claude_active_sessions' AND $__timeFilter(bucket) ORDER BY bucket"
        }
      ]
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Active Worktrees",
      "gridPos": { "h": 7, "w": 6, "x": 6, "y": 0 },
      "datasource": { "uid": "timescaledb", "type": "postgres" },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": { "mode": "value" }
        },
        "overrides": []
      },
      "options": {
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "center",
        "orientation": "horizontal",
        "reduceOptions": { "values": false, "calcs": ["lastNotNull"], "fields": "" },
        "textMode": "value_and_name"
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "uid": "timescaledb", "type": "postgres" },
          "editorMode": "code",
          "format": "time_series",
          "rawQuery": true,
          "rawSql": "SELECT bucket AS time, avg_val AS value FROM metrics_5m WHERE metric = 'claude_worktrees_active' AND $__timeFilter(bucket) ORDER BY bucket"
        }
      ]
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Avg Session Uptime",
      "gridPos": { "h": 7, "w": 6, "x": 12, "y": 0 },
      "datasource": { "uid": "timescaledb", "type": "postgres" },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "color": { "mode": "value" }
        },
        "overrides": []
      },
      "options": {
        "colorMode": "value",
        "graphMode": "none",
        "justifyMode": "center",
        "orientation": "horizontal",
        "reduceOptions": { "values": false, "calcs": ["lastNotNull"], "fields": "" },
        "textMode": "value_and_name"
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "uid": "timescaledb", "type": "postgres" },
          "editorMode": "code",
          "format": "time_series",
          "rawQuery": true,
          "rawSql": "SELECT bucket AS time, avg(avg_val) AS value FROM metrics_5m WHERE metric = 'claude_session_uptime_sec' AND $__timeFilter(bucket) GROUP BY bucket ORDER BY bucket"
        }
      ]
    },
    {
      "id": 4,
      "type": "stat",
      "title": "Max Session Uptime",
      "gridPos": { "h": 7, "w": 6, "x": 18, "y": 0 },
      "datasource": { "uid": "timescaledb", "type": "postgres" },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "color": { "mode": "value" }
        },
        "overrides": []
      },
      "options": {
        "colorMode": "value",
        "graphMode": "none",
        "justifyMode": "center",
        "orientation": "horizontal",
        "reduceOptions": { "values": false, "calcs": ["lastNotNull"], "fields": "" },
        "textMode": "value_and_name"
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "uid": "timescaledb", "type": "postgres" },
          "editorMode": "code",
          "format": "time_series",
          "rawQuery": true,
          "rawSql": "SELECT bucket AS time, max(avg_val) AS value FROM metrics_5m WHERE metric = 'claude_session_uptime_sec' AND $__timeFilter(bucket) GROUP BY bucket ORDER BY bucket"
        }
      ]
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "Session History",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 7 },
      "datasource": { "uid": "timescaledb", "type": "postgres" },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": { "mode": "palette-classic" },
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 18,
            "lineWidth": 2,
            "showPoints": "never",
            "spanNulls": true
          }
        },
        "overrides": []
      },
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom", "showLegend": true },
        "tooltip": { "mode": "single", "sort": "none" }
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "uid": "timescaledb", "type": "postgres" },
          "editorMode": "code",
          "format": "time_series",
          "rawQuery": true,
          "rawSql": "SELECT bucket AS time, 'sessions' AS metric, avg_val AS value FROM metrics_5m WHERE metric = 'claude_active_sessions' AND $__timeFilter(bucket) ORDER BY bucket"
        }
      ]
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "Session Uptime by Session",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 7 },
      "datasource": { "uid": "timescaledb", "type": "postgres" },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "color": { "mode": "palette-classic" },
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 8,
            "lineWidth": 2,
            "showPoints": "never",
            "spanNulls": true
          }
        },
        "overrides": []
      },
      "options": {
        "legend": { "displayMode": "table", "placement": "bottom", "showLegend": true },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "uid": "timescaledb", "type": "postgres" },
          "editorMode": "code",
          "format": "time_series",
          "rawQuery": true,
          "rawSql": "SELECT bucket AS time, coalesce(labels->>'session_id', 'unknown') AS metric, avg_val AS value FROM metrics_5m WHERE metric = 'claude_session_uptime_sec' AND $__timeFilter(bucket) ORDER BY bucket"
        }
      ]
    },
    {
      "id": 7,
      "type": "timeseries",
      "title": "System Impact: CPU + Sessions",
      "gridPos": { "h": 9, "w": 12, "x": 0, "y": 15 },
      "datasource": { "uid": "timescaledb", "type": "postgres" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 8,
            "lineWidth": 2,
            "showPoints": "never",
            "spanNulls": true
          }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "cpu_percent" },
            "properties": [{ "id": "unit", "value": "percent" }]
          },
          {
            "matcher": { "id": "byName", "options": "sessions" },
            "properties": [
              { "id": "unit", "value": "short" },
              { "id": "custom.axisPlacement", "value": "right" }
            ]
          }
        ]
      },
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom", "showLegend": true },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "uid": "timescaledb", "type": "postgres" },
          "editorMode": "code",
          "format": "time_series",
          "rawQuery": true,
          "rawSql": "SELECT bucket AS time, 'cpu_percent' AS metric, avg(avg_val) AS value FROM metrics_5m WHERE metric = 'cpu_usage_percent' AND $__timeFilter(bucket) GROUP BY bucket ORDER BY bucket"
        },
        {
          "refId": "B",
          "datasource": { "uid": "timescaledb", "type": "postgres" },
          "editorMode": "code",
          "format": "time_series",
          "rawQuery": true,
          "rawSql": "SELECT bucket AS time, 'sessions' AS metric, avg_val AS value FROM metrics_5m WHERE metric = 'claude_active_sessions' AND $__timeFilter(bucket) ORDER BY bucket"
        }
      ]
    },
    {
      "id": 8,
      "type": "timeseries",
      "title": "System Impact: RAM + Worktrees",
      "gridPos": { "h": 9, "w": 12, "x": 12, "y": 15 },
      "datasource": { "uid": "timescaledb", "type": "postgres" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 8,
            "lineWidth": 2,
            "showPoints": "never",
            "spanNulls": true
          }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "memory_used" },
            "properties": [{ "id": "unit", "value": "bytes" }]
          },
          {
            "matcher": { "id": "byName", "options": "worktrees" },
            "properties": [
              { "id": "unit", "value": "short" },
              { "id": "custom.axisPlacement", "value": "right" }
            ]
          }
        ]
      },
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom", "showLegend": true },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "uid": "timescaledb", "type": "postgres" },
          "editorMode": "code",
          "format": "time_series",
          "rawQuery": true,
          "rawSql": "SELECT bucket AS time, 'memory_used' AS metric, avg_val AS value FROM metrics_5m WHERE metric = 'memory_used_bytes' AND $__timeFilter(bucket) ORDER BY bucket"
        },
        {
          "refId": "B",
          "datasource": { "uid": "timescaledb", "type": "postgres" },
          "editorMode": "code",
          "format": "time_series",
          "rawQuery": true,
          "rawSql": "SELECT bucket AS time, 'worktrees' AS metric, avg_val AS value FROM metrics_5m WHERE metric = 'claude_worktrees_active' AND $__timeFilter(bucket) ORDER BY bucket"
        }
      ]
    }
  ]
}
