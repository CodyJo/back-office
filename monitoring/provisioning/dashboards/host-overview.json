          "editorMode": "code",
          "format": "time_series",
          "rawQuery": true,
          "rawSql": "SELECT bucket AS time, labels->>'label' AS metric, avg_val AS value FROM metrics_5m WHERE source = 'sensors' AND metric = 'cpu_temp_celsius' AND $__timeFilter(bucket) ORDER BY bucket"
        }
      ]
    },
    {
