      "targets": [
        {
          "refId": "A",
          "datasource": { "uid": "timescaledb", "type": "postgres" },
          "editorMode": "code",
          "format": "time_series",
          "rawQuery": true,
          "rawSql": "SELECT bucket AS time, 'memory_used_bytes' AS metric, avg_val AS value FROM metrics_5m WHERE metric = 'memory_used_bytes' AND $__timeFilter(bucket) ORDER BY bucket"
        },
        {
          "refId": "B",
          "datasource": { "uid": "timescaledb", "type": "postgres" },
          "editorMode": "code",
          "format": "time_series",
          "rawQuery": true,
          "rawSql": "SELECT bucket AS time, 'memory_available_bytes' AS metric, avg_val AS value FROM metrics_5m WHERE metric = 'memory_available_bytes' AND $__timeFilter(bucket) ORDER BY bucket"
        }
      ]
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "Swap Usage",
      "gridPos": { "h": 8, "w": 6, "x": 18, "y": 9 },
      "datasource": { "uid": "timescaledb", "type": "postgres" },
      "fieldConfig": {
        "defaults": {
          "unit": "bytes",
          "color": { "mode": "palette-classic" },
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 18,
            "lineWidth": 2,
            "showPoints": "never",
            "spanNulls": true
          }
        },
        "overrides": []
      },
      "options": {
        "legend": { "displayMode": "hidden", "placement": "bottom", "showLegend": false },
        "tooltip": { "mode": "single", "sort": "none" }
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "uid": "timescaledb", "type": "postgres" },
          "editorMode": "code",
          "format": "time_series",
          "rawQuery": true,
          "rawSql": "SELECT bucket AS time, avg_val AS value FROM metrics_5m WHERE metric = 'swap_used_bytes' AND $__timeFilter(bucket) ORDER BY bucket"
        }
      ]
    },
    {
      "id": 6,
      "type": "bargauge",
      "title": "Disk Usage per Device",
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 17 },
      "datasource": { "uid": "timescaledb", "type": "postgres" },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 85 },
              { "color": "red", "value": 90 }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "displayMode": "gradient",
        "orientation": "horizontal",
        "reduceOptions": { "values": true, "calcs": ["lastNotNull"], "fields": "" },
        "showUnfilled": true
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "uid": "timescaledb", "type": "postgres" },
          "editorMode": "code",
          "format": "table",
          "rawQuery": true,
          "rawSql": "SELECT labels->>'device' AS metric, max(100.0 * avg_val / NULLIF((SELECT avg_val FROM metrics_5m m2 WHERE m2.metric = 'disk_total_bytes' AND m2.labels->>'device' = metrics_5m.labels->>'device' AND $__timeFilter(m2.bucket) ORDER BY m2.bucket DESC LIMIT 1), 0)) AS value FROM metrics_5m WHERE metric = 'disk_used_bytes' AND $__timeFilter(bucket) GROUP BY labels->>'device' ORDER BY labels->>'device'"
        }
      ]
    },
    {
      "id": 7,
      "type": "timeseries",
      "title": "Disk I/O",
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 17 },
      "datasource": { "uid": "timescaledb", "type": "postgres" },
      "fieldConfig": {
        "defaults": {
          "unit": "Bps",
          "color": { "mode": "palette-classic" },
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 10,
            "lineWidth": 2,
            "showPoints": "never",
            "spanNulls": true
          }
        },
        "overrides": []
      },
      "options": {
        "legend": { "displayMode": "table", "placement": "bottom", "showLegend": true },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "uid": "timescaledb", "type": "postgres" },
          "editorMode": "code",
          "format": "time_series",
          "rawQuery": true,
          "rawSql": "SELECT bucket AS time, concat(labels->>'device', ' ', replace(metric, 'disk_io_', '')) AS metric, avg_val AS value FROM metrics_5m WHERE metric IN ('disk_io_read_bytes', 'disk_io_write_bytes') AND $__timeFilter(bucket) ORDER BY bucket"
        }
      ]
    },
    {
      "id": 8,
      "type": "timeseries",
      "title": "Network Traffic (wlp8s0)",
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 17 },
      "datasource": { "uid": "timescaledb", "type": "postgres" },
      "fieldConfig": {
        "defaults": {
          "unit": "Bps",
          "color": { "mode": "palette-classic" },
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 12,
            "lineWidth": 2,
            "showPoints": "never",
