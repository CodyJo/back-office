      "targets": [
        {
          "refId": "A",
          "datasource": { "uid": "timescaledb", "type": "postgres" },
          "editorMode": "code",
          "format": "time_series",
          "rawQuery": true,
          "rawSql": "SELECT bucket AS time, replace(metric, 'network_', '') AS metric, avg_val AS value FROM metrics_5m WHERE metric IN ('network_rx_bytes', 'network_tx_bytes') AND labels->>'device' = 'wlp8s0' AND $__timeFilter(bucket) ORDER BY bucket"
        }
      ]
    },
    {
      "id": 9,
      "type": "timeseries",
      "title": "CPU Temperature",
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 25 },
      "datasource": { "uid": "timescaledb", "type": "postgres" },
      "fieldConfig": {
        "defaults": {
          "unit": "celsius",
          "thresholds": {
            "mode": "absolute",
