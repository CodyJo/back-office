{
  "uid": "host-overview",
  "title": "Host Overview — borg",
  "tags": ["monitoring", "host", "borg"],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "editable": true,
  "refresh": "1m",
  "graphTooltip": 0,
  "time": {
    "from": "now-6h",
    "to": "now"
  },
  "annotations": {
    "list": [
      {
        "builtIn": 1,
        "datasource": {
          "type": "datasource",
          "uid": "-- Grafana --"
        },
        "enable": true,
        "hide": true,
        "iconColor": "rgba(0, 211, 255, 1)",
        "name": "Annotations & Alerts",
        "type": "dashboard"
      }
    ]
  },
  "templating": {
    "list": []
  },
  "panels": [
    {
      "id": 1,
      "type": "timeseries",
      "title": "CPU Usage per Core",
      "gridPos": { "h": 9, "w": 12, "x": 0, "y": 0 },
      "datasource": { "uid": "timescaledb", "type": "postgres" },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "color": { "mode": "palette-classic" },
          "custom": {
            "axisCenteredZero": false,
            "axisPlacement": "auto",
            "drawStyle": "line",
            "fillOpacity": 18,
            "lineWidth": 2,
            "showPoints": "never",
            "spanNulls": true,
            "stacking": { "mode": "normal", "group": "A" }
          }
        },
        "overrides": []
      },
      "options": {
        "legend": { "displayMode": "table", "placement": "bottom", "showLegend": true },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "uid": "timescaledb", "type": "postgres" },
          "editorMode": "code",
          "format": "time_series",
          "rawQuery": true,
          "rawSql": "SELECT bucket AS time, labels->>'core' AS metric, avg_val AS value FROM metrics_5m WHERE metric = 'cpu_usage_percent' AND $__timeFilter(bucket) ORDER BY bucket"
        }
      ]
    },
    {
      "id": 2,
      "type": "timeseries",
      "title": "Load Average (1m / 5m)",
      "gridPos": { "h": 9, "w": 12, "x": 12, "y": 0 },
      "datasource": { "uid": "timescaledb", "type": "postgres" },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": { "mode": "palette-classic" },
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 8,
            "lineWidth": 2,
            "showPoints": "never",
            "spanNulls": true
          }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "load_avg_1m" },
            "properties": [{ "id": "color", "value": { "fixedColor": "yellow", "mode": "fixed" } }]
          },
          {
            "matcher": { "id": "byName", "options": "load_avg_5m" },
            "properties": [{ "id": "color", "value": { "fixedColor": "green", "mode": "fixed" } }]
          }
        ]
      },
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom", "showLegend": true },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "uid": "timescaledb", "type": "postgres" },
          "editorMode": "code",
          "format": "time_series",
          "rawQuery": true,
          "rawSql": "SELECT bucket AS time, metric, avg_val AS value FROM metrics_5m WHERE metric IN ('load_avg_1m', 'load_avg_5m') AND $__timeFilter(bucket) ORDER BY bucket"
        }
      ]
    },
    {
      "id": 3,
      "type": "gauge",
      "title": "RAM Used",
      "gridPos": { "h": 8, "w": 6, "x": 0, "y": 9 },
      "datasource": { "uid": "timescaledb", "type": "postgres" },
      "fieldConfig": {
        "defaults": {
          "unit": "bytes",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 25769803776 },
              { "color": "red", "value": 34359738368 }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "orientation": "auto",
        "reduceOptions": { "values": false, "calcs": ["lastNotNull"], "fields": "" },
        "showThresholdLabels": false,
        "showThresholdMarkers": true
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "uid": "timescaledb", "type": "postgres" },
          "editorMode": "code",
          "format": "time_series",
          "rawQuery": true,
          "rawSql": "SELECT bucket AS time, avg_val AS value FROM metrics_5m WHERE metric = 'memory_used_bytes' AND $__timeFilter(bucket) ORDER BY bucket"
        }
      ]
    },
    {
      "id": 4,
      "type": "timeseries",
      "title": "RAM Usage History",
      "gridPos": { "h": 8, "w": 12, "x": 6, "y": 9 },
      "datasource": { "uid": "timescaledb", "type": "postgres" },
      "fieldConfig": {
        "defaults": {
          "unit": "bytes",
          "color": { "mode": "palette-classic" },
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 14,
            "lineWidth": 2,
            "showPoints": "never",
