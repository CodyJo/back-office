    {
      "id": 3,
      "type": "stat",
      "title": "PCIe Link",
      "gridPos": { "h": 8, "w": 6, "x": 18, "y": 0 },
      "datasource": { "uid": "timescaledb", "type": "postgres" },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": { "mode": "value" }
        },
        "overrides": []
      },
      "options": {
        "colorMode": "value",
        "graphMode": "none",
        "justifyMode": "center",
        "orientation": "horizontal",
        "reduceOptions": { "values": false, "calcs": ["lastNotNull"], "fields": "" },
        "textMode": "value_and_name"
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "uid": "timescaledb", "type": "postgres" },
          "editorMode": "code",
          "format": "table",
          "rawQuery": true,
          "rawSql": "SELECT concat('Gen ', max(CASE WHEN metric = 'gpu_pcie_link_gen' THEN avg_val END)::text, ' x', max(CASE WHEN metric = 'gpu_pcie_link_width' THEN avg_val END)::text) AS value FROM metrics_5m WHERE metric IN ('gpu_pcie_link_gen', 'gpu_pcie_link_width') AND $__timeFilter(bucket)"
        }
      ]
    },
