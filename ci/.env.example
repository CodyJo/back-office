# Bunny Magic Container — CI/CD Webhook Server environment variables
# Copy to .env and fill in real values. Never commit .env to source control.

# Indicates the server is running in CI mode (enables deploy on push to main)
DEPLOY_CI=1

# GitHub webhook secret — must match the secret configured in repo Settings > Webhooks
GITHUB_WEBHOOK_SECRET=

# GitHub personal access token with repo:status scope (for posting commit statuses)
GITHUB_TOKEN=

# GitHub repository owner/org and name (used for commit status API calls)
GITHUB_REPO_OWNER=
GITHUB_REPO_NAME=

# Bunny.net Storage Zone access key (used by `backoffice sync`)
BUNNY_STORAGE_KEY=

# Bunny.net API key (used by `backoffice sync` and Bunny CLI)
BUNNY_API_KEY=
